NEXTAUTH_URL=https://your-domain.vercel.app
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Users — use bcrypt hashed passwords in production
# Generate: node -e "const b=require('bcryptjs');console.log(b.hashSync('yourpassword',10))"
USERS=[{"username":"morna","password":"$2a$10$...hash...","name":"Morna"},{"username":"user2","password":"$2a$10$...hash...","name":"User Two"}]

# ── Supabase (optional — enables database persistence) ──────────────
# Get these from: supabase.com → your project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
NEXT_PUBLIC_SUPABASE_ENABLED=true
